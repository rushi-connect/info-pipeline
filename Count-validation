Here are the validation queries focusing on hdp_update_user (info-insert/info-update), run_date, aep_usage_dt, and key columns:

1. Count by insert vs update

SELECT hdp_update_user, COUNT(*) as cnt
FROM usage_nonvee.reading_ivl_nonvee_oh
GROUP BY hdp_update_user;
2. Count by run_date and insert/update

SELECT run_date, hdp_update_user, COUNT(*) as cnt
FROM usage_nonvee.reading_ivl_nonvee_oh
GROUP BY run_date, hdp_update_user
ORDER BY run_date DESC, hdp_update_user;
3. Count by usage date and insert/update

SELECT aep_usage_dt, hdp_update_user, COUNT(*) as cnt
FROM usage_nonvee.reading_ivl_nonvee_oh
GROUP BY aep_usage_dt, hdp_update_user
ORDER BY aep_usage_dt DESC, hdp_update_user;
4. Key column NULL validation (split by insert/update)

SELECT 
    hdp_update_user,
    COUNT(*) as total,
    SUM(CASE WHEN serialnumber IS NULL THEN 1 ELSE 0 END) as null_serial,
    SUM(CASE WHEN aep_premise_nb IS NULL THEN 1 ELSE 0 END) as null_premise,
    SUM(CASE WHEN aep_service_point IS NULL THEN 1 ELSE 0 END) as null_svc_point,
    SUM(CASE WHEN aep_derived_uom IS NULL THEN 1 ELSE 0 END) as null_derived_uom,
    SUM(CASE WHEN aep_channel_id IS NULL THEN 1 ELSE 0 END) as null_channel,
    SUM(CASE WHEN endtimeperiod IS NULL THEN 1 ELSE 0 END) as null_endtime,
    SUM(CASE WHEN starttimeperiod IS NULL THEN 1 ELSE 0 END) as null_starttime,
    SUM(CASE WHEN value IS NULL THEN 1 ELSE 0 END) as null_value,
    SUM(CASE WHEN aep_mtr_install_ts IS NULL THEN 1 ELSE 0 END) as null_mtr_install,
    SUM(CASE WHEN aep_mtr_removal_ts IS NULL THEN 1 ELSE 0 END) as null_mtr_removal,
    SUM(CASE WHEN aep_city IS NULL THEN 1 ELSE 0 END) as null_city,
    SUM(CASE WHEN aep_state IS NULL THEN 1 ELSE 0 END) as null_state,
    SUM(CASE WHEN aep_zip IS NULL THEN 1 ELSE 0 END) as null_zip
FROM usage_nonvee.reading_ivl_nonvee_oh
GROUP BY hdp_update_user;
5. Sample records for info-insert vs info-update

-- info-insert sample
SELECT serialnumber, aep_premise_nb, aep_service_point, aep_channel_id, 
       aep_derived_uom, endtimeperiod, starttimeperiod, value, 
       aep_usage_dt, hdp_insert_dttm, hdp_update_dttm, hdp_update_user
FROM usage_nonvee.reading_ivl_nonvee_oh
WHERE hdp_update_user = 'info-insert'
LIMIT 10;

-- info-update sample
SELECT serialnumber, aep_premise_nb, aep_service_point, aep_channel_id, 
       aep_derived_uom, endtimeperiod, starttimeperiod, value, 
       aep_usage_dt, hdp_insert_dttm, hdp_update_dttm, hdp_update_user
FROM usage_nonvee.reading_ivl_nonvee_oh
WHERE hdp_update_user = 'info-update'
LIMIT 10;
6. Dev vs Prod comparison (run on both)

SELECT 
    hdp_update_user,
    aep_usage_dt,
    COUNT(*) as cnt,
    COUNT(DISTINCT serialnumber) as distinct_meters,
    SUM(CASE WHEN aep_premise_nb IS NULL THEN 1 ELSE 0 END) as null_premise_cnt
FROM usage_nonvee.reading_ivl_nonvee_oh
GROUP BY hdp_update_user, aep_usage_dt
ORDER BY aep_usage_dt DESC, hdp_update_user;
