Lg Queries 
Q1: Identify serial numbers and aep_usage_dt from the latest run

Select * from xfrm_interval"."reading_ivl_nonvee_incr where hdp_insert_dttm >= ‘’ limit 100
Or  
Select * from usage_nonvee.reading_ivl_nonvee_tx where hdp_insert_dttm >= ‘’ limit 100
Q2:
select 
serialnumber,aep_usage_dt,aep_derived_uom,aep_channel_id,aep_raw_value, value,aep_service_point,aep_premise_nb
from "xfrm_interval"."reading_ivl_nonvee_incr" 
where ((hdp_update_dttm >= TIMESTAMP '2026-03-23 00:00:00' and hdp_update_dttm < TIMESTAMP '2026-03-24 00:00:00') or 
(hdp_insert_dttm >= TIMESTAMP '2026-03-23 00:00:00' and hdp_insert_dttm < TIMESTAMP '2026-03-24 00:00:00'))
and aep_opco ='tx'
and serialnumber ='200306248' 
-- and aep_premise_nb = '971213203'
-- and aep_channel_id = '102'
and aep_endtime_utc = '1774257300'

Q3:
select * from usage_nonvee.reading_ivl_nonvee_tx
where aep_usage_dt = '2026-03-25'
and serialnumber ='109103600'
and aep_endtime_utc = '1774415700'
