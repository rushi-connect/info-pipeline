2. info-insert validation (run on both DEV and PROD, compare results)

SELECT 
    'info-insert' as check_type,
    COUNT(*) as total_rows,
    COUNT(DISTINCT serialnumber) as dist_meters,
    COUNT(DISTINCT aep_usage_dt) as dist_usage_dates,
    COUNT(DISTINCT aep_premise_nb) as dist_premises,
    COUNT(DISTINCT aep_channel_id) as dist_channels,
