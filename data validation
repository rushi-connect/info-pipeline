# Validation A: starttime/endtime calculation
spark.sql("""
    SELECT 
        hdp_update_user,
        COUNT(*) as total,
        SUM(CASE WHEN starttimeperiod IS NULL THEN 1 ELSE 0 END) as null_starttime,
        SUM(CASE WHEN endtimeperiod IS NULL THEN 1 ELSE 0 END) as null_endtime,
        SUM(CASE WHEN aep_sec_per_intrvl IS NULL THEN 1 ELSE 0 END) as null_interval_secs,
        SUM(CASE 
            WHEN (unix_timestamp(substr(endtimeperiod, 1, 19), "yyyy-MM-dd'T'HH:mm:ss") 
                - unix_timestamp(substr(starttimeperiod, 1, 19), "yyyy-MM-dd'T'HH:mm:ss")) 
                != CAST(aep_sec_per_intrvl AS INT)
            THEN 1 ELSE 0 
        END) as mismatched_interval_count
    FROM usage_nonvee.reading_ivl_nonvee_oh
    WHERE hdp_update_user IN ('info-insert', 'info-update')
      AND aep_usage_dt = '2026-04-01'
      AND hdp_insert_dttm >= (SELECT DATE(MAX(hdp_insert_dttm)) FROM usage_nonvee.reading_ivl_nonvee_oh 
                              WHERE aep_usage_dt = '2026-04-01' AND hdp_update_user IN ('info-insert', 'info-update'))
    GROUP BY hdp_update_user
""").show(truncate=False)

