Validation C: aep_service_point logic

SELECT 
    hdp_update_user,
    CASE 
        WHEN aep_premise_nb IS NOT NULL AND aep_tarf_pnt_nb IS NOT NULL AND aep_mtr_pnt_nb IS NOT NULL 
            THEN 'ALL_PRESENT'
        ELSE 'HAS_NULL'
    END as input_status,
    SUM(CASE WHEN aep_service_point IS NOT NULL THEN 1 ELSE 0 END) as svc_point_populated,
    SUM(CASE WHEN aep_service_point IS NULL THEN 1 ELSE 0 END) as svc_point_null,
    COUNT(*) as cnt
FROM usage_nonvee.reading_ivl_nonvee_oh
WHERE hdp_update_user IN ('info-insert', 'info-update')
  AND aep_usage_dt = '2026-04-01'
  AND hdp_insert_dttm >= (SELECT MAX(hdp_insert_dttm)::date FROM usage_nonvee.reading_ivl_nonvee_oh 
                          WHERE aep_usage_dt = '2026-04-01' AND hdp_update_user IN ('info-insert', 'info-update'))
GROUP BY hdp_update_user,
    CASE 
        WHEN aep_premise_nb IS NOT NULL AND aep_tarf_pnt_nb IS NOT NULL AND aep_mtr_pnt_nb IS NOT NULL 
            THEN 'ALL_PRESENT'
        ELSE 'HAS_NULL'
    END;

-- Format check
SELECT 
    hdp_update_user,
    aep_premise_nb,
    aep_tarf_pnt_nb,
    aep_mtr_pnt_nb,
    aep_service_point,
    concat(aep_premise_nb, '-', aep_tarf_pnt_nb, '-', aep_mtr_pnt_nb) as expected,
    CASE 
        WHEN aep_service_point = concat(aep_premise_nb, '-', aep_tarf_pnt_nb, '-', aep_mtr_pnt_nb) 
        THEN 'MATCH' ELSE 'MISMATCH' 
    END as check_result
FROM usage_nonvee.reading_ivl_nonvee_oh
WHERE hdp_update_user IN ('info-insert', 'info-update')
  AND aep_usage_dt = '2026-04-01'
  AND aep_service_point IS NOT NULL
  AND hdp_insert_dttm >= (SELECT MAX(hdp_insert_dttm)::date FROM usage_nonvee.reading_ivl_nonvee_oh 
                          WHERE aep_usage_dt = '2026-04-01' AND hdp_update_user IN ('info-insert', 'info-update'))
LIMIT 20;
