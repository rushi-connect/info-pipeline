Validation B: MACS join

-- Match vs no-match
SELECT 
    hdp_update_user,
    CASE WHEN aep_premise_nb IS NOT NULL THEN 'MACS_MATCHED' ELSE 'MACS_NOT_MATCHED' END as join_status,
    COUNT(*) as cnt,
    COUNT(DISTINCT serialnumber) as dist_meters
FROM usage_nonvee.reading_ivl_nonvee_oh
WHERE hdp_update_user IN ('info-insert', 'info-update')
  AND aep_usage_dt = '2026-04-01'
  AND hdp_insert_dttm >= (SELECT MAX(hdp_insert_dttm)::date FROM usage_nonvee.reading_ivl_nonvee_oh 
                          WHERE aep_usage_dt = '2026-04-01' AND hdp_update_user IN ('info-insert', 'info-update'))
GROUP BY hdp_update_user,
    CASE WHEN aep_premise_nb IS NOT NULL THEN 'MACS_MATCHED' ELSE 'MACS_NOT_MATCHED' END
ORDER BY hdp_update_user, join_status;

