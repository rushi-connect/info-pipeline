Note: I used DATE(MAX(hdp_insert_dttm)) instead of ::date since Spark SQL uses DATE() cast function. If your Spark version doesn't support subqueries in WHERE, you can do it in two steps:


# Step 1: Get latest run date
latest_run = spark.sql("""
    SELECT DATE(MAX(hdp_insert_dttm)) as latest_dt
    FROM usage_nonvee.reading_ivl_nonvee_oh
    WHERE aep_usage_dt = '2026-04-01' 
      AND hdp_update_user IN ('info-insert', 'info-update')
""").collect()[0].latest_dt

print(f"Latest run date: {latest_run}")

# Step 2: Use it in queries
spark.sql(f"""
    SELECT ...
    FROM usage_nonvee.reading_ivl_nonvee_oh
    WHERE hdp_update_user IN ('info-insert', 'info-update')
      AND aep_usage_dt = '2026-04-01'
      AND hdp_insert_dttm >= '{latest_run}'
    ...
""").show(truncate=False)
